{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RatingFactors": {
    "BaseRate": 500,
    "YoungDriverAge": 25,
    "YoungDriverFactor": 1.8,
    "OlderDriverAge": 70,
